#!/bin/sh

[ -f "/etc/config/nikki" ] || exit 0
command -v uci >/dev/null 2>&1 || exit 0

changed=0

ensure_list_entry() {
	local option="$1"
	local value="$2"
	local current

	current="$(uci -q get "$option" 2>/dev/null | tr ' ' '\n')"
	printf '%s\n' "$current" | grep -Fx "$value" >/dev/null 2>&1 && return 0

	uci add_list "$option=$value"
	changed=1
}

ensure_list_entry "nikki.proxy.reserved_ip" "100.64.0.0/10"
ensure_list_entry "nikki.proxy.reserved_ip6" "fd7a:115c:a1e0::/48"

[ "$changed" -eq 1 ] && uci commit nikki

exit 0
