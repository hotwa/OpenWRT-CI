config enroll 'main'
	option enabled '0'
	option login_server 'https://headscale.jmsu.top'
	option auth_key_file '/etc/tailscale/headscale.authkey'
	option provision_url ''
	option provision_token_file ''
	option hostname_prefix 'openwrt'
	option hostname_override ''
	option ssh '1'
	option accept_dns '0'
	option accept_routes '0'
	option advertise_routes ''
	option max_attempts '60'
	option retry_interval '10'
	option restore_gate_file '/root/wrtbak/firstboot/gate.json'
	option restore_gate_attempts '90'
	option restore_gate_interval '10'
	option delete_auth_key_file '1'
