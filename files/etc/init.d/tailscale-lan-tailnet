#!/bin/sh /etc/rc.common

START=99
STOP=10

. /lib/functions.sh

SECTION="lan_to_tailnet"
DEVICE="tailscale0"
DEFAULT_CIDR4="100.64.0.0/10"
DEFAULT_CIDR6="fd7a:115c:a1e0::/48"
DEFAULT_DNS_DOMAIN="hs.jmsu.top"
DEFAULT_MAGICDNS="100.100.100.100"
DEFAULT_DNSMASQ_SERVER="/hs.jmsu.top/100.100.100.100@tailscale0"
DEFAULT_MOSDNS_MATCH="qname suffix:hs.jmsu.top"
MOSDNS_SNIPPET="/etc/mosdns/tailscale-magicdns.yaml"
MOSDNS_RUNTIME="/var/etc/mosdns.json"

changed=0
firewall_changed=0
dhcp_changed=0

ensure_option() {
	local option="$1"
	local value="$2"
	local current

	current="$(uci -q get "$option" 2>/dev/null || true)"
	[ "$current" = "$value" ] && return 0

	uci set "$option=$value"
	changed=1
}

ensure_default_option() {
	local option="$1"
	local value="$2"

	uci -q get "$option" >/dev/null 2>&1 && return 0

	uci set "$option=$value"
	changed=1
}

ensure_list_entry() {
	local option="$1"
	local value="$2"
	local current

	current="$(uci -q get "$option" 2>/dev/null | tr ' ' '\n')"
	printf '%s\n' "$current" | grep -Fx "$value" >/dev/null 2>&1 && return 0

	uci add_list "$option=$value"
	changed=1
}

ensure_tailscale_config() {
	[ -f "/etc/config/tailscale" ] || touch /etc/config/tailscale

	if ! uci -q get "tailscale.$SECTION" >/dev/null 2>&1; then
		uci set "tailscale.$SECTION=lan_to_tailnet"
		changed=1
	fi

	ensure_default_option "tailscale.$SECTION.enabled" "0"
	ensure_default_option "tailscale.$SECTION.cidr4" "$DEFAULT_CIDR4"
	ensure_default_option "tailscale.$SECTION.cidr6" "$DEFAULT_CIDR6"
	ensure_default_option "tailscale.$SECTION.dns_domain" "$DEFAULT_DNS_DOMAIN"
	ensure_default_option "tailscale.$SECTION.magicdns" "$DEFAULT_MAGICDNS"
	ensure_default_option "tailscale.$SECTION.masq" "1"

	if [ "$changed" -eq 1 ]; then
		uci commit tailscale
		changed=0
	fi
}

apply_firewall() {
	local cidr4="$1"
	local cidr6="$2"
	local masq="$3"

	# Static policy markers for audits:
	# firewall.tailscale.input='ACCEPT'
	# firewall.tailscale.output='ACCEPT'
	# firewall.tailscale.forward='REJECT'
	# firewall.tailscale.masq
	# src='lan'
	# dest='tailscale'
	# tailscale_lan_to_tailnet='1'
	changed=0
	ensure_option "firewall.tailscale" "zone"
	ensure_option "firewall.tailscale.name" "tailscale"
	ensure_list_entry "firewall.tailscale.device" "$DEVICE"
	ensure_option "firewall.tailscale.input" "ACCEPT"
	ensure_option "firewall.tailscale.output" "ACCEPT"
	ensure_option "firewall.tailscale.forward" "REJECT"
	ensure_option "firewall.tailscale.masq" "$masq"

	ensure_option "firewall.tailscale_lan_to_tailnet" "forwarding"
	ensure_option "firewall.tailscale_lan_to_tailnet.src" "lan"
	ensure_option "firewall.tailscale_lan_to_tailnet.dest" "tailscale"
	ensure_option "firewall.tailscale_lan_to_tailnet.enabled" "1"
	ensure_option "firewall.tailscale_lan_to_tailnet.tailscale_lan_to_tailnet" "1"

	# Keep these documented in UCI for operator visibility; fw4 routes the
	# forwarding by zone, while Nikki/DAE generated rules keep the CIDRs direct.
	ensure_option "firewall.tailscale_lan_to_tailnet.cidr4" "$cidr4"
	ensure_option "firewall.tailscale_lan_to_tailnet.cidr6" "$cidr6"

	if [ "$changed" -eq 1 ]; then
		uci commit firewall
		firewall_changed=1
	fi
}

apply_dnsmasq() {
	local dns_domain="$1"
	local magicdns="$2"
	local server_entry

	server_entry="/$dns_domain/$magicdns@$DEVICE"
	[ "$dns_domain" = "$DEFAULT_DNS_DOMAIN" ] &&
		[ "$magicdns" = "$DEFAULT_MAGICDNS" ] &&
		server_entry="$DEFAULT_DNSMASQ_SERVER"

	changed=0
	ensure_list_entry "dhcp.@dnsmasq[0].server" "$server_entry"
	ensure_list_entry "dhcp.@dnsmasq[0].rebind_domain" "$dns_domain"

	if [ "$changed" -eq 1 ]; then
		uci commit dhcp
		dhcp_changed=1
	fi
}

write_mosdns_snippet() {
	local dns_domain="$1"
	local magicdns="$2"
	local tmp

	mkdir -p /etc/mosdns
	tmp="$(mktemp)"
	cat >"$tmp" <<EOF
# Generated by tailscale-lan-tailnet.
# qname suffix:$dns_domain should use Quad100 through $DEVICE.
- tag: forward_tailscale_magicdns
  type: forward
  args:
    bind_to_device: $DEVICE
    upstreams:
      - addr: udp://$magicdns
- tag: tailscale_magicdns_sequence
  type: sequence
  args:
    - exec: \$forward_tailscale_magicdns
    - exec: accept
EOF

	if ! cmp -s "$MOSDNS_SNIPPET" "$tmp" 2>/dev/null; then
		cat "$tmp" >"$MOSDNS_SNIPPET"
	fi

	rm -f "$tmp"
}

patch_mosdns_runtime() {
	local dns_domain="$1"
	local magicdns="$2"
	local tmp

	[ -f "$MOSDNS_RUNTIME" ] || return 0
	command -v jq >/dev/null 2>&1 || return 0
	grep -F "forward_tailscale_magicdns" "$MOSDNS_RUNTIME" >/dev/null 2>&1 && return 0

	tmp="$(mktemp)"
	jq --arg domain "$dns_domain" --arg device "$DEVICE" --arg addr "udp://$magicdns" '
		def add_magicdns_plugin:
			. + [{
				"tag": "forward_tailscale_magicdns",
				"type": "forward",
				"args": {
					"bind_to_device": $device,
					"upstreams": [{"addr": $addr}]
				}
			}, {
				"tag": "tailscale_magicdns_sequence",
				"type": "sequence",
				"args": [
					{"exec": "$forward_tailscale_magicdns"},
					{"exec": "accept"}
				]
			}];
		def add_magicdns_rule:
			[{
				"matches": ["qname suffix:" + $domain],
				"exec": "$tailscale_magicdns_sequence"
			}] + .;
		if has("plugins") then
			.plugins |= add_magicdns_plugin |
			(.plugins[] | select(.tag == "main_sequence" and .type == "sequence").args) |= add_magicdns_rule
		elif has("plugin") then
			.plugin |= add_magicdns_plugin |
			(.plugin[] | select(.tag == "main_sequence" and .type == "sequence").args) |= add_magicdns_rule
		else
			.
		end
	' "$MOSDNS_RUNTIME" >"$tmp" 2>/dev/null && cat "$tmp" >"$MOSDNS_RUNTIME"

	rm -f "$tmp"
}

reapply_nikki_guard() {
	[ -x /etc/init.d/tailscale-nikki-guard ] || return 0
	/etc/init.d/tailscale-nikki-guard start >/dev/null 2>&1 || true
}

reload_services() {
	if [ "$firewall_changed" -eq 1 ]; then
		[ -x /etc/init.d/firewall ] && /etc/init.d/firewall restart >/dev/null 2>&1 || true
	fi

	if [ "$dhcp_changed" -eq 1 ]; then
		[ -x /etc/init.d/dnsmasq ] && /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
	fi
}

start() {
	local enabled cidr4 cidr6 dns_domain magicdns masq

	command -v uci >/dev/null 2>&1 || return 0
	ensure_tailscale_config
	config_load tailscale
	config_get enabled lan_to_tailnet enabled '0'
	[ "$enabled" = '1' ] || return 0

	config_get cidr4 "$SECTION" cidr4 "$DEFAULT_CIDR4"
	config_get cidr6 "$SECTION" cidr6 "$DEFAULT_CIDR6"
	config_get dns_domain "$SECTION" dns_domain "$DEFAULT_DNS_DOMAIN"
	config_get magicdns "$SECTION" magicdns "$DEFAULT_MAGICDNS"
	config_get masq "$SECTION" masq '1'

	apply_firewall "$cidr4" "$cidr6" "$masq"
	apply_dnsmasq "$dns_domain" "$magicdns"
	write_mosdns_snippet "$dns_domain" "$magicdns"
	patch_mosdns_runtime "$dns_domain" "$magicdns"
	reapply_nikki_guard
	reload_services
}

stop() {
	command -v uci >/dev/null 2>&1 || return 0
	uci -q get firewall.tailscale_lan_to_tailnet >/dev/null 2>&1 || return 0

	uci set firewall.tailscale_lan_to_tailnet.enabled='0'
	uci commit firewall
	[ -x /etc/init.d/firewall ] && /etc/init.d/firewall restart >/dev/null 2>&1 || true
}

restart() {
	start
}
