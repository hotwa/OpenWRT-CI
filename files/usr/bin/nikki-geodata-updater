#!/bin/sh

set -eu

LOGGER_TAG="${LOGGER_TAG:-nikki-geodata-updater}"
TARGET_DIR="${TARGET_DIR:-/etc/nikki/run}"
SERVICE_NAME="${SERVICE_NAME:-nikki}"
LOCK_DIR="${LOCK_DIR:-/var/run/nikki-geodata-updater.lock}"
TMP_ROOT="${TMP_ROOT:-/tmp}"
PROXY_URL="${PROXY_URL:-}"
PROXY_USER="${PROXY_USER:-}"

FILES="geoip.dat geosite.dat geoip.metadb"
PRIMARY_BASE="${PRIMARY_BASE:-https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest}"
CHECKSUM_BASE="${CHECKSUM_BASE:-$PRIMARY_BASE}"
DEFAULT_MIRROR_BASES='https://cdn.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release
https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release'
MIRROR_BASES="${MIRROR_BASES:-$DEFAULT_MIRROR_BASES}"

log() {
	echo "$@"
	if command -v logger >/dev/null 2>&1; then
		logger -t "$LOGGER_TAG" "$@"
	fi
}

cleanup() {
	rc="$?"
	[ -n "${TMP_DIR:-}" ] && rm -rf "$TMP_DIR"
	if [ "${LOCK_ACQUIRED:-0}" = "1" ]; then
		rmdir "$LOCK_DIR" >/dev/null 2>&1 || true
	fi
	exit "$rc"
}

require_cmd() {
	command -v "$1" >/dev/null 2>&1 || {
		log "missing required command: $1"
		exit 1
	}
}

fetch_file() {
	url="$1"
	out="$2"

	if [ -n "$PROXY_URL" ]; then
		if [ -n "$PROXY_USER" ]; then
			curl -fsSL \
				--proxy "$PROXY_URL" \
				--proxy-user "$PROXY_USER" \
				--connect-timeout 10 \
				--max-time 180 \
				--retry 2 \
				--retry-delay 2 \
				--retry-all-errors \
				-o "$out" \
				"$url"
		else
			curl -fsSL \
				--proxy "$PROXY_URL" \
				--connect-timeout 10 \
				--max-time 180 \
				--retry 2 \
				--retry-delay 2 \
				--retry-all-errors \
				-o "$out" \
				"$url"
		fi
	else
		curl -fsSL \
			--connect-timeout 10 \
			--max-time 180 \
			--retry 2 \
			--retry-delay 2 \
			--retry-all-errors \
			-o "$out" \
			"$url"
	fi
}

fetch_expected_sum() {
	file="$1"
	out="$2"

	fetch_file "$CHECKSUM_BASE/$file.sha256sum" "$out"
}

download_verified_file() {
	file="$1"
	expected_sum="$2"
	out="$3"

	if fetch_file "$PRIMARY_BASE/$file" "$out" && [ "$(sha256sum "$out" | awk '{print $1}')" = "$expected_sum" ]; then
		return 0
	fi
	rm -f "$out"

	for base in $MIRROR_BASES; do
		if fetch_file "$base/$file" "$out" && [ "$(sha256sum "$out" | awk '{print $1}')" = "$expected_sum" ]; then
			return 0
		fi
		rm -f "$out"
	done

	return 1
}

restart_service() {
	if ! /etc/init.d/"$SERVICE_NAME" restart; then
		log "failed to restart $SERVICE_NAME"
		return 1
	fi

	if ! /etc/init.d/"$SERVICE_NAME" running >/dev/null 2>&1; then
		log "$SERVICE_NAME is not running after restart"
		return 1
	fi

	return 0
}

require_cmd curl
require_cmd sha256sum
require_cmd awk

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
	log "another update is already running"
	exit 0
fi
LOCK_ACQUIRED=1

TMP_DIR="$(mktemp -d "$TMP_ROOT/nikki-geodata-updater.XXXXXX")"
trap cleanup EXIT INT TERM

mkdir -p "$TARGET_DIR"

need_update=0
changed_files=""

for file in $FILES; do
	sum_file="$TMP_DIR/$file.sha256sum"
	stage_file="$TMP_DIR/$file"
	target_file="$TARGET_DIR/$file"

	log "fetching checksum for $file"
	if ! fetch_expected_sum "$file" "$sum_file"; then
		log "failed to fetch checksum for $file"
		exit 1
	fi

	expected_sum="$(awk 'NR==1 {print $1}' "$sum_file")"
	if [ -z "$expected_sum" ]; then
		log "empty checksum for $file"
		exit 1
	fi

	if [ -f "$target_file" ]; then
		current_sum="$(sha256sum "$target_file" | awk '{print $1}')"
		if [ "$current_sum" = "$expected_sum" ]; then
			log "$file is already up to date"
			continue
		fi
	fi

	log "downloading $file"
	if ! download_verified_file "$file" "$expected_sum" "$stage_file"; then
		log "failed to download a verified copy of $file"
		exit 1
	fi

	need_update=1
	if [ -n "$changed_files" ]; then
		changed_files="$changed_files $file"
	else
		changed_files="$file"
	fi
done

if [ "$need_update" -eq 0 ]; then
	log "all nikki geodata files are already up to date"
	exit 0
fi

for file in $changed_files; do
	target_file="$TARGET_DIR/$file"
	stage_file="$TMP_DIR/$file"

	if [ -f "$target_file" ]; then
		cp -f "$target_file" "$TMP_DIR/$file.bak"
	fi

	cp -f "$stage_file" "$target_file"
	chmod 644 "$target_file"
done

if restart_service; then
	log "nikki geodata update completed: $changed_files"
	exit 0
fi

log "restoring previous geodata after restart failure"
for file in $changed_files; do
	target_file="$TARGET_DIR/$file"
	backup_file="$TMP_DIR/$file.bak"

	if [ -f "$backup_file" ]; then
		cp -f "$backup_file" "$target_file"
		chmod 644 "$target_file"
	else
		rm -f "$target_file"
	fi
done

restart_service || true
exit 1
