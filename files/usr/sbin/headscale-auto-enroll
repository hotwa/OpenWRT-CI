#!/bin/sh

CONFIG="headscale_auto_enroll"
SECTION="main"
DONE_FILE="${HEADSCALE_AUTO_ENROLL_DONE_FILE:-/etc/tailscale/auto-enroll.done}"
TAG="headscale-auto-enroll"
LOCK_DIR="${HEADSCALE_AUTO_ENROLL_LOCK_DIR:-/var/run/headscale-auto-enroll.lock}"
TAILSCALE_INIT="${HEADSCALE_AUTO_ENROLL_TAILSCALE_INIT:-/etc/init.d/tailscale}"

log() {
	logger -t "$TAG" "$*"
}

cfg() {
	local name="$1"
	local default="$2"
	local value

	value="$(uci -q get "$CONFIG.$SECTION.$name" 2>/dev/null || true)"
	[ -n "$value" ] || value="$default"
	printf '%s' "$value"
}

bool_arg() {
	case "$1" in
		1|true|yes|on) printf 'true' ;;
		*) printf 'false' ;;
	esac
}

is_enrolled() {
	tailscale status --json 2>/dev/null | grep -q '"BackendState"[[:space:]]*:[[:space:]]*"Running"'
}

release_enroll_lock() {
	local lock_pid
	[ -d "$LOCK_DIR" ] || return 0
	lock_pid=$(sed -n '1p' "$LOCK_DIR/pid" 2>/dev/null || true)
	[ "$lock_pid" = "$$" ] || return 0
	rm -rf "$LOCK_DIR"
}

acquire_enroll_lock() {
	local lock_pid
	if mkdir "$LOCK_DIR" 2>/dev/null; then
		printf '%s\n' "$$" >"$LOCK_DIR/pid"
		trap release_enroll_lock EXIT HUP INT TERM
		return 0
	fi
	lock_pid=$(sed -n '1p' "$LOCK_DIR/pid" 2>/dev/null || true)
	case "$lock_pid" in
		''|*[!0-9]*) ;;
		*)
			if kill -0 "$lock_pid" 2>/dev/null; then
				log "another enrollment attempt is active; skip duplicate trigger"
				return 1
			fi
			;;
	esac
	rm -rf "$LOCK_DIR"
	if mkdir "$LOCK_DIR" 2>/dev/null; then
		printf '%s\n' "$$" >"$LOCK_DIR/pid"
		trap release_enroll_lock EXIT HUP INT TERM
		return 0
	fi
	log "unable to acquire enrollment lock"
	return 1
}

wrtbak_restore_enabled() {
	local value
	value="$(uci -q get wrtbak.main.firstboot_auto_enabled 2>/dev/null || true)"
	case "$value" in
		1|true|yes|on|enabled) return 0 ;;
	esac
	return 1
}

wrtbak_gate_state() {
	local gate_file="$1" state
	[ -f "$gate_file" ] || {
		printf 'missing'
		return 0
	}
	if command -v jsonfilter >/dev/null 2>&1; then
		state="$(jsonfilter -i "$gate_file" -e '@.state' 2>/dev/null || true)"
	else
		state="$(sed -n 's/.*"state"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$gate_file" | sed -n '1p')"
	fi
	[ -n "$state" ] || state=invalid
	printf '%s' "$state"
}

wait_for_wrtbak_gate() {
	local gate_file="$1" max_attempts="$2" retry_interval="$3"
	local attempt=0 state
	if ! wrtbak_restore_enabled; then
		printf 'disabled'
		return 0
	fi
	while [ "$attempt" -lt "$max_attempts" ]; do
		state="$(wrtbak_gate_state "$gate_file")"
		case "$state" in
			already_done|restored|no_backup|failed_final|disabled)
				log "wrtbak recovery gate opened with state=$state"
				printf '%s' "$state"
				return 0
				;;
			reboot_pending)
				log "wrtbak restore applied; waiting for the requested reboot"
				;;
		esac
		attempt=$((attempt + 1))
		[ "$attempt" -lt "$max_attempts" ] || break
		sleep "$retry_interval"
	done
	log "wrtbak recovery gate timed out after $max_attempts attempt(s); preserving remote rescue enrollment"
	printf 'timeout'
}

reload_recovered_state() {
	local attempt=0
	"$TAILSCALE_INIT" restart >/dev/null 2>&1 || return 1
	while [ "$attempt" -lt 30 ]; do
		is_enrolled && return 0
		attempt=$((attempt + 1))
		sleep 2
	done
	return 1
}

wait_for_wan() {
	local max_attempts="$1"
	local retry_interval="$2"
	local attempt=0

	while [ "$attempt" -lt "$max_attempts" ]; do
		if ip route get 1.1.1.1 >/dev/null 2>&1 || ip route | grep -q '^default '; then
			return 0
		fi
		attempt=$((attempt + 1))
		sleep "$retry_interval"
	done

	return 1
}

fetch_provision_key() {
	local provision_url="$1"
	local token_file="$2"
	local token=""

	[ -n "$provision_url" ] || return 1
	[ -f "$token_file" ] && token="$(sed -n '1p' "$token_file" | tr -d '\r\n')"

	if command -v curl >/dev/null 2>&1; then
		if [ -n "$token" ]; then
			curl -fsS --max-time 20 -H "Authorization: Bearer $token" "$provision_url"
		else
			curl -fsS --max-time 20 "$provision_url"
		fi
		return $?
	fi

	if command -v wget >/dev/null 2>&1; then
		if [ -n "$token" ]; then
			wget -q -T 20 -O - --header="Authorization: Bearer $token" "$provision_url"
		else
			wget -q -T 20 -O - "$provision_url"
		fi
		return $?
	fi

	return 1
}

read_auth_key() {
	local auth_key_file="$1"
	local provision_url="$2"
	local provision_token_file="$3"

	if [ -f "$auth_key_file" ]; then
		sed -n '1p' "$auth_key_file" | tr -d '\r\n'
		return 0
	fi

	fetch_provision_key "$provision_url" "$provision_token_file" | sed -n '1p' | tr -d '\r\n'
}

build_hostname() {
	local override="$1"
	local prefix="$2"
	local board=""
	local hostname=""

	if [ -n "$override" ]; then
		printf '%s' "$override" | tr -cs 'A-Za-z0-9_.-' '-'
		return 0
	fi

	hostname="$(uci -q get system.@system[0].hostname 2>/dev/null || true)"
	[ -n "$hostname" ] || hostname="$(cat /proc/sys/kernel/hostname 2>/dev/null || true)"
	[ -n "$hostname" ] || hostname="router"

	if [ -r /tmp/sysinfo/board_name ]; then
		board="$(sed -n '1p' /tmp/sysinfo/board_name | tr -cs 'A-Za-z0-9_.-' '-')"
	fi

	if [ -n "$prefix" ]; then
		printf '%s-%s' "$prefix" "$hostname" | tr -cs 'A-Za-z0-9_.-' '-'
	elif [ -n "$board" ]; then
		printf '%s-%s' "$hostname" "$board" | tr -cs 'A-Za-z0-9_.-' '-'
	else
		printf '%s' "$hostname" | tr -cs 'A-Za-z0-9_.-' '-'
	fi
}

run_tailscale_up() {
	local login_server="$1"
	local auth_key="$2"
	local hostname="$3"
	local ssh_enabled="$4"
	local accept_dns="$5"
	local accept_routes="$6"
	local advertise_routes="$7"

	if [ -n "$advertise_routes" ]; then
		tailscale up \
			--login-server="$login_server" \
			--auth-key="$auth_key" \
			--hostname="$hostname" \
			--ssh="$(bool_arg "$ssh_enabled")" \
			--accept-dns="$(bool_arg "$accept_dns")" \
			--accept-routes="$(bool_arg "$accept_routes")" \
			--advertise-routes="$advertise_routes"
	else
		tailscale up \
			--login-server="$login_server" \
			--auth-key="$auth_key" \
			--hostname="$hostname" \
			--ssh="$(bool_arg "$ssh_enabled")" \
			--accept-dns="$(bool_arg "$accept_dns")" \
			--accept-routes="$(bool_arg "$accept_routes")"
	fi
}

apply_runtime_preferences() {
	local ssh_enabled="$1"
	local accept_dns="$2"
	local accept_routes="$3"
	local advertise_routes="$4"

	if [ -n "$advertise_routes" ]; then
		tailscale set \
			--ssh="$(bool_arg "$ssh_enabled")" \
			--accept-dns="$(bool_arg "$accept_dns")" \
			--accept-routes="$(bool_arg "$accept_routes")" \
			--advertise-routes="$advertise_routes"
	else
		tailscale set \
			--ssh="$(bool_arg "$ssh_enabled")" \
			--accept-dns="$(bool_arg "$accept_dns")" \
			--accept-routes="$(bool_arg "$accept_routes")"
	fi
}

main() {
	local enabled login_server auth_key_file provision_url provision_token_file
	local hostname_override hostname_prefix ssh_enabled accept_dns accept_routes advertise_routes
	local max_attempts retry_interval delete_auth_key_file auth_key hostname
	local restore_gate_file restore_gate_attempts restore_gate_interval restore_gate_state
	local attempt=0

	enabled="$(cfg enabled 0)"
	case "$enabled" in
		1|true|yes|on) ;;
		*) log "disabled by UCI; skip enrollment"; exit 0 ;;
	esac

	command -v tailscale >/dev/null 2>&1 || { log "tailscale command not found"; exit 0; }
	acquire_enroll_lock || exit 0

	login_server="$(cfg login_server https://headscale.jmsu.top)"
	auth_key_file="$(cfg auth_key_file /etc/tailscale/headscale.authkey)"
	provision_url="$(cfg provision_url '')"
	provision_token_file="$(cfg provision_token_file '')"
	hostname_override="$(cfg hostname_override '')"
	hostname_prefix="$(cfg hostname_prefix openwrt)"
	ssh_enabled="$(cfg ssh 1)"
	accept_dns="$(cfg accept_dns 0)"
	accept_routes="$(cfg accept_routes 0)"
	advertise_routes="$(cfg advertise_routes '')"
	max_attempts="$(cfg max_attempts 60)"
	retry_interval="$(cfg retry_interval 10)"
	restore_gate_file="$(cfg restore_gate_file /root/wrtbak/firstboot/gate.json)"
	restore_gate_attempts="$(cfg restore_gate_attempts 90)"
	restore_gate_interval="$(cfg restore_gate_interval 10)"
	delete_auth_key_file="$(cfg delete_auth_key_file 1)"

	if is_enrolled; then
		if apply_runtime_preferences "$ssh_enabled" "$accept_dns" "$accept_routes" "$advertise_routes" >/dev/null 2>&1; then
			log "tailscale already enrolled; runtime preferences applied"
		else
			log "tailscale already enrolled; failed to apply runtime preferences"
		fi
		touch "$DONE_FILE" 2>/dev/null || true
		exit 0
	fi

	restore_gate_state="$(wait_for_wrtbak_gate "$restore_gate_file" "$restore_gate_attempts" "$restore_gate_interval")"
	case "$restore_gate_state" in
		already_done|restored)
			if reload_recovered_state; then
				if apply_runtime_preferences "$ssh_enabled" "$accept_dns" "$accept_routes" "$advertise_routes" >/dev/null 2>&1; then
					log "recovered tailscale state; runtime preferences applied"
				else
					log "recovered tailscale state; failed to apply runtime preferences"
				fi
				touch "$DONE_FILE" 2>/dev/null || true
				exit 0
			fi
			log "wrtbak gate opened without a usable recovered tailscale state"
			;;
	esac

	"$TAILSCALE_INIT" enable >/dev/null 2>&1 || true
	"$TAILSCALE_INIT" start >/dev/null 2>&1 || true

	wait_for_wan "$max_attempts" "$retry_interval" || {
		log "WAN did not become ready within retry window"
		exit 1
	}

	auth_key="$(read_auth_key "$auth_key_file" "$provision_url" "$provision_token_file")"
	if [ -z "$auth_key" ]; then
		log "no auth key available; set $auth_key_file or provision_url"
		exit 1
	fi

	hostname="$(build_hostname "$hostname_override" "$hostname_prefix")"

	while [ "$attempt" -lt "$max_attempts" ]; do
		if run_tailscale_up "$login_server" "$auth_key" "$hostname" "$ssh_enabled" "$accept_dns" "$accept_routes" "$advertise_routes" >/dev/null 2>&1; then
			touch "$DONE_FILE" 2>/dev/null || true
			if [ -f "$auth_key_file" ] && [ "$(bool_arg "$delete_auth_key_file")" = "true" ]; then
				rm -f "$auth_key_file"
			fi
			log "enrolled to $login_server as $hostname"
			exit 0
		fi

		attempt=$((attempt + 1))
		sleep "$retry_interval"
	done

	log "tailscale up failed after $max_attempts attempt(s)"
	exit 1
}

main "$@"
