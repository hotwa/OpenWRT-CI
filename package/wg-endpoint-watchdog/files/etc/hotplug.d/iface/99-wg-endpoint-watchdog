#!/bin/sh

TAG="wg-endpoint-watchdog"
CONFIG_NAME="wg_endpoint_watchdog"
FUNCTIONS_LIB="${WG_ENDPOINT_WATCHDOG_FUNCTIONS:-/lib/functions.sh}"
REFRESH_BIN="${WG_ENDPOINT_REFRESH_BIN:-/usr/bin/wg-endpoint-refresh}"

[ "$ACTION" = "ifup" ] || exit 0

case "$INTERFACE" in
	wan|wan6|pppoe-wan) ;;
	*) exit 0 ;;
esac

# shellcheck disable=SC1090
. "$FUNCTIONS_LIB"

log_msg() {
	logger -t "$TAG" "$*"
}

is_uint() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

schedule_instance() {
	section="$1"
	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get wan_ifup_delay "$section" wan_ifup_delay
	[ -n "$wan_ifup_delay" ] || return 0

	if ! is_uint "$wan_ifup_delay"; then
		log_msg "skip invalid wan_ifup_delay instance=$section delay=$wan_ifup_delay"
		return 0
	fi

	log_msg "schedule WAN refresh instance=$section delay=$wan_ifup_delay trigger=$INTERFACE"
	(
		sleep "$wan_ifup_delay"
		"$REFRESH_BIN" "$section" wan-ifup
	) &
}

config_load "$CONFIG_NAME"
config_foreach schedule_instance instance
