#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

TAG="wg-endpoint-watchdog"
CONFIG_NAME="wg_endpoint_watchdog"
FUNCTIONS_LIB="${WG_ENDPOINT_WATCHDOG_FUNCTIONS:-/lib/functions.sh}"
WATCHDOG_BIN="${WG_ENDPOINT_WATCHDOG_BIN:-/usr/bin/wg-endpoint-watchdog}"
REFRESH_BIN="${WG_ENDPOINT_REFRESH_BIN:-/usr/bin/wg-endpoint-refresh}"

# shellcheck disable=SC1090
. "$FUNCTIONS_LIB"

log_msg() {
	logger -t "$TAG" "$*"
}

is_uint() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

schedule_boot_refresh() {
	section="$1"
	config_get_bool enabled "$section" enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get boot_delay "$section" boot_delay
	[ -n "$boot_delay" ] || return 0

	if ! is_uint "$boot_delay"; then
		log_msg "skip invalid boot_delay instance=$section delay=$boot_delay"
		return 0
	fi

	log_msg "schedule boot refresh instance=$section delay=$boot_delay"
	(
		sleep "$boot_delay"
		"$REFRESH_BIN" "$section" boot
	) &
}

start_service() {
	procd_open_instance
	procd_set_param command /bin/sh -c "while :; do sleep 600; $WATCHDOG_BIN; done"
	procd_close_instance

	config_load "$CONFIG_NAME"
	config_foreach schedule_boot_refresh instance
}

stop_service() {
	log_msg "service stopped; UCI config preserved"
}
